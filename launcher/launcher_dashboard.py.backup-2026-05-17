        ref_cards = (
            '<div class="cd-time cd-time-ref">'
            '<div class="cd-time-lbl">Target</div>'
            '<div class="cd-time-val">Win the Race!</div>'
            f'<div class="cd-time-ctx">{escape(cfg.get("goal", ""))}</div>'
