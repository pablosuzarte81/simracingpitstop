.bh-bib .bh-num{font:900 12px/1 var(--display);color:#fff;background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.30);padding:5px 8px 4px;letter-spacing:1.4px;border-radius:2px}
