    # PB + reference cards
    pb_card = (
        f'<div class="cd-time cd-time-you">'
        f'<div class="cd-time-lbl">{escape(you_label)}</div>'
        f'<div class="cd-time-val mono">{_fmt_ms(pb_ms)}</div>'
