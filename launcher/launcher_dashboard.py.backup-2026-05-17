.hh-kicker::before{content:"";display:inline-block;width:28px;height:2px;background:var(--max)}
.hh-title{margin:0 0 22px;font:900 64px/0.95 var(--display);letter-spacing:-1.8px;color:#fff;max-width:14ch}
