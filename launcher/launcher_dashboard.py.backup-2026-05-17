    # Title with stylised "vs" between the two driver surnames
    a_last = (a.get("driver") or "").split()[-1].upper() if a.get("driver") else "A"
    b_last = (b.get("driver") or "").split()[-1].upper() if b.get("driver") else "B"
    venue_bits = []
    if cfg.get("track_label"):
