def _length_m(s):
    """Parse 'X.YYY km' or 'NNNN m' into meters for sorting."""
    if not s:
        return 0
    s = str(s).strip().lower()
    m = re.search(r'([\d.,]+)\s*(km|m\b)', s)
    if not m:
        m = re.search(r'[\d.,]+', s)
        if not m:
            return 0
        try:
            v = float(m.group().replace(",", "."))
        except ValueError:
            return 0
        return int(v if v > 100 else v * 1000)
    try:
        v = float(m.group(1).replace(",", "."))
    except ValueError:
        return 0
    return int(v * 1000) if m.group(2) == "km" else int(v)


